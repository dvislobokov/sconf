# vault.secrets — локальный файл секретов для разработки без Vault.
#
# Подхватывается автоматически, если лежит в рабочей директории приложения и
# переменная VAULT_SECRETS_FILE не задана (явная переменная имеет приоритет).
# При использовании файла VAULT_ADDR и аутентификация не нужны вовсе.
#
# Формат: отображение «полный путь секрета → его поля». Пути — ТЕ ЖЕ, что в
# конфиге приложения (VAULT_MOUNTPATH к файлу не применяется). Поля кладутся
# так, как их отдал бы Vault. Файл перечитывается при каждом фоновом
# обновлении, так что правки видны без перезапуска. Подойдёт и JSON.
#
# Скопируйте в vault.secrets, добавьте vault.secrets в .gitignore.

# ---------------------------------------------------------------------------
# 1. secret.UserPass — логин/пароль.
# ---------------------------------------------------------------------------

# Динамические креды движка database.
#   Config:  DbCreds secret.UserPass `yaml:"db_cred"`
#   config:  db_cred: database/creds/app-role
# Логин берётся из username, пароль — из password.
database/creds/app-role:
  username: dev-user
  password: dev-password

# Статические креды database (ротация на стороне Vault) — поля те же.
#   config:  db_static: database/static-creds/app
database/static-creds/app:
  username: app
  password: static-dev-password

# Active Directory: пароль лежит в current_password — UserPass берёт его
# автоматически (current_password имеет приоритет над password).
#   config:  ad_creds: ad/static-cred/svc
ad/static-cred/svc:
  username: svc-account
  current_password: rotated-dev-password

# Нестандартные имена полей: переопределяются параметрами пути. Параметры
# в ключе файла НЕ указываются — только чистый путь.
#   config:  custom: kv/data/legacy?username_field=login&password_field=secret
kv/data/legacy:
  login: legacy-user
  secret: legacy-password

# Креды из ОДНОГО текстового поля KV-секрета (?field=): значение поля — текст
# в формате JSON, YAML или TOML (пробуются по очереди именно в этом порядке).
#   config:  redis:    A/APP/OSH/KV/secrets?field=redis
#   config:  postgres: A/APP/OSH/KV/secrets?field=postgres
#   config:  rabbit:   A/APP/OSH/KV/secrets?field=rabbit
A/APP/OSH/KV/secrets:
  # JSON в одну строку
  redis: '{"username": "redis-svc", "password": "redis-pw"}'
  # YAML многострочным литералом
  postgres: |
    username: pg-svc
    password: pg-pw
  # TOML
  rabbit: |
    username = "rabbit-svc"
    password = "rabbit-pw"

# ---------------------------------------------------------------------------
# 2. secret.Cert — сертификат движка pki.
# ---------------------------------------------------------------------------

# Параметры выпуска (?common_name=...&ttl=...) в ключе файла не указываются —
# они имеют смысл только для настоящего Vault. Ключ — путь до "?".
#   Config:  WebCert secret.Cert `yaml:"web_cert"`
#   config:  web_cert: pki/issue/web?common_name=app.example.com&ttl=24h
pki/issue/web:
  certificate: |
    -----BEGIN CERTIFICATE-----
    ...dev cert...
    -----END CERTIFICATE-----
  private_key: |
    -----BEGIN PRIVATE KEY-----
    ...dev key...
    -----END PRIVATE KEY-----
  issuing_ca: |
    -----BEGIN CERTIFICATE-----
    ...dev ca...
    -----END CERTIFICATE-----
  # ca_chain — список PEM-сертификатов (может отсутствовать).
  ca_chain:
    - |
      -----BEGIN CERTIFICATE-----
      ...intermediate...
      -----END CERTIFICATE-----
  serial_number: dev-01

# ---------------------------------------------------------------------------
# 3. secret.KV — весь KV-секрет как набор пар ключ→значение.
# ---------------------------------------------------------------------------

# Для KV v2 путь в конфиге содержит сегмент data (secret/data/...), но в файле
# обёртка data/metadata НЕ нужна — поля кладутся сразу.
#   Config:  Extra secret.KV `yaml:"extra"`
#   config:  extra: secret/data/myapp
# Затем: cfg.Extra.Get("region"), cfg.Extra.Values().
secret/data/myapp:
  region: eu-central-1
  tier: dev
  feature_x_enabled: "true"

# ---------------------------------------------------------------------------
# 4. secret.Value — одно поле KV-секрета.
# ---------------------------------------------------------------------------

#   Config:  APIKey secret.Value `yaml:"api_key"`
#   config:  api_key: secret/data/billing?field=stripe_key
# Если ?field= опущен, поле в секрете должно быть ровно одно.
secret/data/billing:
  stripe_key: sk_test_local
  webhook_secret: whsec_local

# ---------------------------------------------------------------------------
# 5. AddVaultKV — KV-секрет как слой конфигурации (не поле-секрет).
# ---------------------------------------------------------------------------

#   builder:  sconf.New().AddVaultKV("secret/data/app-config")
# Поля раскладываются в дерево конфигурации; вложенность поддерживается.
secret/data/app-config:
  log_level: debug
  db:
    host: localhost
    port: 5432

# ---------------------------------------------------------------------------
# Про обновление: параметр ?refresh=30s задаётся в КОНФИГЕ приложения, не
# здесь. Аренды (lease) у файла нет, поэтому без ?refresh= действует интервал
# по умолчанию (30 минут); файл при каждом обновлении перечитывается заново.
# ---------------------------------------------------------------------------
